{
  "name": "import_script",
  "version": "1.0.0",
  "description": "Dragons Lair import scripts",
  "scripts": {
    "sync": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=sync",
    "sync:store2": "cross-env ENV_FILE=.env.store2 node src/index.js --command=sync",
    "fetch": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=fetch",
    "fetch:store2": "cross-env ENV_FILE=.env.store2 node src/index.js --command=fetch",
    "fetch:products": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=fetch --type=products",
    "fetch:products:mickie": "cross-env ENV_FILE=.env.mickieofsweden node src/index.js --command=fetch --type=products",
    "fetch:collections": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=fetch --type=collections",
    "fetch:customers": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=fetch --type=customers",
    "export": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=export",
    "export:store2": "cross-env ENV_FILE=.env.store2 node src/index.js --command=export",
    "export:products": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=export --type=products",
    "export:collections": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=export --type=collections",
    "export:customers": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=export --type=customers",
    "export:translations": "cross-env ENV_FILE=.env.dragonslair node src/index.js --command=export --type=translations",
    "sync:mickie": "cross-env ENV_FILE=.env.mickieofsweden node src/index.js --command=sync",
    "help": "node src/index.js --help",
    "fetch-products": "node scripts/products/processProducts.js",
    "export-products": "node scripts/products/exportToExcel.js",
    "update-product-collections": "node scripts/collections/exportMatrixifyCollections.js",
    "update-product-price": "node scripts/products/exportMatrixifyPriceUpdate.js",
    "update-metafields": "node scripts/products/updateMetafieldsForMatrixify.js",
    "update-vendor": "node scripts/products/exportVendorUpdate.js",
    "export-collections": "node scripts/collections/exportCollections.js",
    "update-product-collections-only": "node scripts/products/updateProductCollections.js",
    "update-subcollections": "node scripts/products/updateSubcollections.js",
    "summary": "node scripts/products/generateSummary.js",
    "export-short-desc": "node scripts/products/exportShortDescUpdate.js",
    "export-short-desc-translations": "node scripts/products/exportShortDescTranslations.js",
    "export-customers": "node scripts/customers/exportCustomersMatrixify.js",
    "topup-products": "node scripts/fetch/fetchTopUpProducts.js",
    "topup-translations": "node scripts/products/exportTopUpTranslations.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cross-env": "^7.0.3",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "stream-json": "^2.1.0",
    "xlsx": "^0.18.5"
  }
}
