# Environment Variables for Vendre Import Scripts
# =====================================================
# 
# IMPORTANT: Do NOT use this file directly!
# 
# Instead, create store-specific .env files:
#   - .env.dragonslair  (for Dragons Lair store)
#   - .env.store2       (for second store)
# 
# Run scripts with: ENV_FILE=.env.dragonslair npm run sync
# 
# =====================================================

# Required Variables for Each Store:

# Store Information
STORE_NAME=dragonslair                          # Unique identifier for the store
STORE_DISPLAY_NAME=Dragons Lair                 # Human-readable store name
API_URL=https://dragonslair.se/API/1            # Vendre API base URL
API_KEY=your-api-key-here                       # Vendre API key

# Tax Classes (tax_class_id -> percentage)
TAX_CLASS_2=25                                  # Hög - 25%
TAX_CLASS_3=6                                   # Låg - 6%
TAX_CLASS_4=12                                  # Medel - 12%
TAX_CLASS_5=0                                   # Extra låg - 0%

# Vendre Spec Field IDs for Product Metadata
# (These are store-specific - check your Vendre admin panel)
SPEC_FIELD_BGG_ID=1603
SPEC_FIELD_YEAR_PUBLISHED=1604
SPEC_FIELD_MIN_PLAYERS=1605
SPEC_FIELD_MAX_PLAYERS=1606
SPEC_FIELD_PLAY_TIME=1608
SPEC_FIELD_MIN_AGE=1609
SPEC_FIELD_BGG_WEIGHT=1610
SPEC_FIELD_BGG_COMPLEXITY=1611
SPEC_FIELD_MECHANICS=1612
SPEC_FIELD_DESIGNERS=1613
SPEC_FIELD_PUBLISHERS=1614

# Customer Tags
CUSTOMER_TAG_IMPORT=vendre-import               # Tag for imported customers
CUSTOMER_TAG_INACTIVE=inactive                  # Tag for inactive customers

# Phone Number Formatting
PHONE_COUNTRY_CODE=+46                          # Default country code
PHONE_REMOVE_LEADING_ZERO=true                  # Remove leading zero from phone numbers

# Optional: Debug mode
# DEBUG=false                                   # Set to 'true' to see stack traces on errors
